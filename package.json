{
  "name": "mytokens",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "lint": "tsc --noEmit && eslint .",
    "fix": "eslint . --fix",
    "tc": "tsc --noEmit --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "build": "tsdown --config ./tsdown.config.ts",
    "build:watch": "concurrently --names \"R,T\" --prefix-colors \"blue.dim,magenta.dim\" \"tsdown --config ./tsdown.config.ts --watch\" \"tsc --noEmit --watch\"",
    "start": "rux ./src/index.ts",
    "dev": "run ./src/index.ts"
  },
  "bin": {
    "mtkn": "./dist/index.js",
    "mtkns": "./dist/index.js",
    "mytoken": "./dist/index.js",
    "mytokens": "./dist/index.js",
    "openusage": "./dist/index.js"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "fuse.js": "^7.3.0",
    "husky": "^9.1.7",
    "ms": "^2.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rolldown": "1.0.0-rc.13",
    "table": "^6.9.0",
    "tsdown": "^0.15.12",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "ulid": "^3.0.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "sqlite3": "^6.0.1"
  }
}
